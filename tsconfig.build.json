{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types"
  },
  "include": [
    "index.ts",
    "types/**/*.d.ts",
    "src/core/**/*.ts",
    "src/import/**/*.ts",
    "src/web/**/*.ts"
  ],
  "exclude": ["**/*.test.ts"]
}

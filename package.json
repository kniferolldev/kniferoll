{
  "name": "@kniferoll/kniferoll",
  "version": "1.0.3",
  "type": "module",
  "license": "MIT",
  "description": "A structured markdown format for recipes — parser, web component, and import engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/kniferolldev/kniferoll.git"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/kniferoll.min.js"
    },
    "./core": {
      "types": "./dist/types/src/core/index.d.ts",
      "default": "./dist/core.js"
    },
    "./import": {
      "types": "./dist/types/src/import/index.d.ts",
      "default": "./dist/import.js"
    },
    "./component": {
      "types": "./dist/types/src/web/index.d.ts",
      "default": "./dist/component.js"
    },
    "./SCHEMA.md": "./SCHEMA.md"
  },
  "files": [
    "dist/",
    "logo/*.svg",
    "logo/*.png",
    "logo/*.ico",
    "SCHEMA.md"
  ],
  "scripts": {
    "kr": "bun src/kr.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun scripts/build.ts",
    "screenshot": "bun scripts/screenshot.ts",
    "prepublishOnly": "bun run typecheck && bun run build && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "linkedom": "^0.18.12",
    "playwright": "^1.56.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "jpeg-js": "^0.4.4"
  }
}

{
  "name": "@kniferoll/kniferoll",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "description": "A structured markdown format for recipes — parser, web component, and import engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/kniferolldev/kniferoll.git"
  },
  "exports": {
    ".": "./dist/kniferoll.min.js",
    "./core": "./src/core/index.ts",
    "./import": "./src/import/index.ts",
    "./component": "./src/web/index.ts",
    "./SCHEMA.md": "./SCHEMA.md"
  },
  "files": [
    "dist/kniferoll.min.js",
    "src/core/",
    "src/import/",
    "src/web/",
    "src/types.ts",
    "logo/*.svg",
    "logo/*.png",
    "logo/*.ico",
    "SCHEMA.md",
    "!**/*.test.ts"
  ],
  "scripts": {
    "kr": "bun src/kr.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun scripts/build.ts",
    "screenshot": "bun scripts/screenshot.ts",
    "prepublishOnly": "bun run typecheck && bun run build && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "linkedom": "^0.18.12",
    "playwright": "^1.56.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "jpeg-js": "^0.4.4"
  }
}
